<launch>
  <arg name="serial_no_camera1"    			default="239122070290"/> 			<!-- Note: Replace with actual serial number -->
  <arg name="serial_no_camera2"    			default="327122076728"/>            <!-- Note: Replace with actual serial number -->
  <arg name="serial_no_camera3"    			default="327122070818"/> 			<!-- Note: Replace with actual serial number -->
  <arg name="serial_no_camera4"    			default="335222073051"/> 			<!-- Note: Replace with actual serial number -->
  <arg name="camera1"              			default="camera_l"/> 		<!-- Note: Replace with camera name -->
  <arg name="camera2"              			default="camera_r"/>		<!-- Note: Replace with camera name -->
<!--   <arg name="camera3"              			default="camera_f"/>		 --><!-- Note: Replace with camera name -->
  <arg name="camera4"              			default="camera_t"/>	
  <arg name="tf_prefix_camera1"         default="$(arg camera1)"/>
  <arg name="tf_prefix_camera2"         default="$(arg camera2)"/>
<!--   <arg name="tf_prefix_camera3"         default="$(arg camera3)"/> -->
  <arg name="tf_prefix_camera4"         default="$(arg camera4)"/>
  <arg name="initial_reset"             default="false"/>
  <arg name="reconnect_timeout"         default="6.0"/>

  <group ns="$(arg camera1)">
    <include file="$(find realsense2_camera)/launch/includes/nodelet.launch.xml">
      <arg name="serial_no"             value="$(arg serial_no_camera1)"/>
      <arg name="tf_prefix"         		value="$(arg tf_prefix_camera1)"/>
      <arg name="initial_reset"         value="$(arg initial_reset)"/>
      <arg name="reconnect_timeout"     value="$(arg reconnect_timeout)"/>
    </include>
  </group>

  <group ns="$(arg camera2)">
    <include file="$(find realsense2_camera)/launch/includes/nodelet.launch.xml">
      <arg name="serial_no"             value="$(arg serial_no_camera2)"/>
      <arg name="tf_prefix"		          value="$(arg tf_prefix_camera2)"/>
      <arg name="initial_reset"         value="$(arg initial_reset)"/>
      <arg name="reconnect_timeout"     value="$(arg reconnect_timeout)"/>
    </include>
  </group>

<!--   <group ns="$(arg camera3)" if="$(eval serial_no_camera3 != '')"> -->
<!--     <include file="$(find realsense2_camera)/launch/includes/nodelet.launch.xml"> -->
<!--       <arg name="serial_no"             value="$(arg serial_no_camera3)"/> -->
<!--       <arg name="tf_prefix"		          value="$(arg tf_prefix_camera3)"/> -->
<!--       <arg name="initial_reset"         value="$(arg initial_reset)"/> -->
<!--       <arg name="reconnect_timeout"     value="$(arg reconnect_timeout)"/> -->
<!--     </include> -->
<!--   </group> -->

  <group ns="$(arg camera4)" if="$(eval serial_no_camera4 != '')">
    <include file="$(find realsense2_camera)/launch/includes/nodelet.launch.xml">
      <arg name="serial_no"             value="$(arg serial_no_camera4)"/>
      <arg name="tf_prefix"		          value="$(arg tf_prefix_camera4)"/>
      <arg name="initial_reset"         value="$(arg initial_reset)"/>
      <arg name="reconnect_timeout"     value="$(arg reconnect_timeout)"/>
    </include>
  </group>  
</launch>
